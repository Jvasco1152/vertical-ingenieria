// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  WORKER
  CLIENT
}

enum ProjectStatus {
  PENDING       // Pendiente de iniciar
  IN_PROGRESS   // En progreso
  PAUSED        // Pausado
  COMPLETED     // Completado
  CANCELLED     // Cancelado
}

enum ProjectPhase {
  MEASUREMENT   // Medición
  DESIGN        // Diseño
  APPROVAL      // Aprobación
  INSTALLATION  // Instalación
  FINISHING     // Acabados
  DELIVERY      // Entrega
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  role          UserRole  @default(CLIENT)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relaciones
  projectsAsClient    Project[]      @relation("ClientProjects")
  projectsAsWorker    ProjectWorker[]
  comments            Comment[]
  notifications       Notification[]

  @@map("users")
}

model Project {
  id              String         @id @default(cuid())
  title           String
  description     String
  location        String
  clientId        String
  status          ProjectStatus  @default(PENDING)
  currentPhase    ProjectPhase   @default(MEASUREMENT)
  progress        Int            @default(0) // 0-100%
  startDate       DateTime?
  estimatedEndDate DateTime?
  actualEndDate   DateTime?
  budget          Float?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relaciones
  client          User           @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  workers         ProjectWorker[]
  images          ProjectImage[]
  comments        Comment[]
  phases          ProjectPhaseLog[]
  notifications   Notification[]

  @@map("projects")
}

model ProjectWorker {
  id         String   @id @default(cuid())
  projectId  String
  workerId   String
  assignedAt DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker     User     @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([projectId, workerId])
  @@map("project_workers")
}

model ProjectImage {
  id          String       @id @default(cuid())
  projectId   String
  url         String
  publicId    String?      // Para Cloudinary
  description String?
  phase       ProjectPhase
  uploadedBy  String
  createdAt   DateTime     @default(now())

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_images")
}

model ProjectPhaseLog {
  id          String       @id @default(cuid())
  projectId   String
  phase       ProjectPhase
  startedAt   DateTime     @default(now())
  completedAt DateTime?
  notes       String?

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_phase_logs")
}

model Comment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

enum QuoteStatus {
  PENDING    // Pendiente
  REVIEWED   // Revisada
  CONVERTED  // Convertida a proyecto
  REJECTED   // Rechazada
}

model QuoteRequest {
  id                        String      @id @default(cuid())

  // Sección 1 — Datos generales
  email                     String
  tipoCliente               String
  tipoClienteOtro           String?
  obraEdificio              String
  direccion                 String
  ciudad                    String
  ciudadOtro                String?
  quienSolicita             String?
  nombreContacto            String?
  telefonoContacto          String?
  emailContacto             String?
  tipoCotizacion            String
  tipoCotizacionOtro        String?
  requerimientoEspecial     String?       // opciones separadas por coma
  requerimientoEspecialOtro String?
  descripcion               String?       // campo legacy, ahora opcional

  // Compartidos entre secciones (medidas de cabina)
  anchoCabina               String?
  fondoCabina               String?

  // Sección 2 — Restauración completa de cabina
  altoCabina                String?
  tipoPuertaCabina          String?
  tipoPuertaCabinaOtro      String?
  anchoPuertaCabina         String?
  altoPuertaCabina          String?
  itemsCotizar              Json?         // { [item]: 'Nuevo'|'Reforma'|'Se conserva'|'N/A' }
  descripcionRestauracion   String?
  fotosRestauracion         String[]      @default([])
  tipoEspejo                Json?         // { [tipo]: { pasamanosTecho: bool, pisoTecho: bool } }
  acabadoPaneles            Json?         // { [material]: { antes: bool, aCotizar: bool } }

  // Compartidos entre S2 y S4 (cielo falso y piso)
  tipoCieloFalso            String?
  tipoCieloFalsoOtro        String?
  tipoPiso                  Json?         // { [material]: { actual: bool, aCotizar: bool } }
  pisoBaseAdicional         String?
  problemasPiso             String[]      @default([])

  // Sección 3 — Cambio de cielo falso
  descripcionCieloFalso     String?
  fotosCieloFalso           String[]      @default([])

  // Sección 4 — Cambio de piso
  descripcionPisoOpcional   String?
  descripcionPiso           String?
  fotosPiso                 String[]      @default([])

  // Sección 5 — Restauración puertas de piso
  numPisos                  String?
  tipoPuertasPiso           String[]      @default([])
  tipoPuertasPisoOtro       String?
  tipoMarco                 String?
  tipoMarcoOtro             String?
  acabadoPuertasLobby       String?
  acabadoPuertasLobbyOtro   String?
  acabadoPuertasOtrosPisos  String?
  acabadoPuertasOtrosOtro   String?
  descripcionPuertas        String?
  fotosPuertas              String[]      @default([])

  // Sección 6 — Requerimiento especial / Otros
  descripcionOtro           String?
  descripcionOtroReq        String?
  fotosOtro                 String[]      @default([])

  // Admin
  status                    QuoteStatus   @default(PENDING)
  adminNotes                String?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  @@map("quote_requests")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
